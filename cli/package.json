{
  "name": "ohmh",
  "version": "0.1.0",
  "description": "Forward webhooks from ohmh.satetsu888.dev to your local dev server.",
  "license": "MIT",
  "bin": {
    "ohmh": "dist/ohmh.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://ohmh.satetsu888.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satetsu888/ohmh.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/satetsu888/ohmh/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "webhook",
    "tunnel",
    "forward",
    "ohmh"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "open": "^10.1.0",
    "prompts": "^2.4.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.13",
    "@types/prompts": "^2.4.9",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
