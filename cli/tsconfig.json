{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": ["ES2022", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "../shared/**/*.ts"],
  // Vitest transforms and type-checks *.test.ts on its own, so exclude them
  // from `tsc --noEmit` (this avoids needing extra `paths` or workspace setup
  // just to resolve vitest from shared/*.test.ts).
  "exclude": ["src/**/*.test.ts", "../shared/**/*.test.ts"]
}
