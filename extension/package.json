{
  "name": "ohmh",
  "displayName": "Oh My Hooks",
  "description": "Receive webhooks at a unique URL and forward them to a local port from VS Code.",
  "version": "0.1.0",
  "publisher": "satetsu888",
  "license": "MIT",
  "homepage": "https://ohmh.satetsu888.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satetsu888/ohmh.git",
    "directory": "extension"
  },
  "bugs": {
    "url": "https://github.com/satetsu888/ohmh/issues"
  },
  "icon": "resources/icon.png",
  "keywords": [
    "webhook",
    "tunnel",
    "forward",
    "ohmh"
  ],
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "ohmh-panel",
          "title": "Oh My Hooks",
          "icon": "resources/panel.svg"
        }
      ]
    },
    "views": {
      "ohmh-panel": [
        {
          "type": "webview",
          "id": "ohmh-webview",
          "name": "Oh My Hooks",
          "canToggleVisibility": true,
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "ohmh.createWebhook",
        "title": "Create New Webhook",
        "icon": "$(add)"
      },
      {
        "command": "ohmh.openSettings",
        "title": "Open Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ohmh.createWebhook",
          "when": "view == ohmh-webview",
          "group": "navigation"
        },
        {
          "command": "ohmh.openSettings",
          "when": "view == ohmh-webview",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "NODE_ENV=production webpack --mode production --devtool hidden-source-map",
    "compile": "webpack",
    "compile:dev": "NODE_ENV=development webpack",
    "compile:prod": "NODE_ENV=production webpack --mode production",
    "watch": "NODE_ENV=development webpack --watch",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.8",
    "@types/node": "^20.16.13",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.94.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.0.0",
    "dotenv": "^17.2.0",
    "eslint": "^9.11.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.2",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0"
  }
}
