{
  "name": "ohmh",
  "displayName": "Oh My Hooks",
  "description": "webhook manager",
  "version": "0.0.1",
  "publisher": "satetsu888",
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "oh-my-hooks-panel",
          "title": "Oh My Hooks",
          "icon": "resources/package-explorer.svg"
        }
      ]
    },
    "views": {
      "oh-my-hooks-panel": [
        {
          "type": "webview",
          "id": "oh-my-hooks-webview",
          "name": "Oh My Hooks",
          "canToggleVisibility": true,
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "oh-my-hooks.createWebhook",
        "title": "Create New Webhook",
        "icon": "$(add)"
      },
      {
        "command": "oh-my-hooks.openSettings",
        "title": "Open Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "oh-my-hooks.createWebhook",
          "when": "view == oh-my-hooks-webview",
          "group": "navigation"
        },
        {
          "command": "oh-my-hooks.openSettings",
          "when": "view == oh-my-hooks-webview",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "compile:dev": "NODE_ENV=development webpack",
    "compile:prod": "NODE_ENV=production webpack --mode production",
    "watch": "NODE_ENV=development webpack --watch",
    "package": "NODE_ENV=production webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.8",
    "@types/node": "^20.16.13",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.94.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "dotenv": "^17.2.0",
    "eslint": "^9.11.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.2",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0"
  }
}
